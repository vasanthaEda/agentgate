# Copy to .env and adjust for local development.
# All defaults below are safe/offline (SQLite + in-process fake Redis) --
# nothing here needs to be filled in to run the test suite or the app locally.

AGENTGATE_DATABASE_URL=sqlite+aiosqlite:///./agentgate.db
AGENTGATE_REDIS_URL=memory://
AGENTGATE_DOWNSTREAM_BASE_URL=http://localhost:9000
AGENTGATE_JWT_SECRET=dev-secret-change-me
AGENTGATE_ADMIN_API_KEY=dev-admin-key-change-me
AGENTGATE_OPENAPI_SPEC_PATH=demo/ecommerce_openapi.json
AGENTGATE_DEFAULT_RATE_LIMIT_PER_MINUTE=60
AGENTGATE_DEFAULT_DAILY_COST_BUDGET_CENTS=500
AGENTGATE_ENVIRONMENT=development
